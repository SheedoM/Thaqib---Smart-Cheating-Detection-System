APP_NAME=Thaqib
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Public HTTPS origin that serves the frontend. Keep same-origin via nginx when possible.
CORS_ORIGINS=https://thaqib.example.edu

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
INTERNAL_EVENT_TOKEN=replace-with-a-private-random-token-at-least-24-chars
SETUP_BOOTSTRAP_TOKEN=replace-with-a-one-time-private-random-token-at-least-24-chars
SETUP_PRIVATE_NETWORK_ONLY=true
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

POSTGRES_DB=thaqib
POSTGRES_USER=thaqib
POSTGRES_PASSWORD=replace-with-a-strong-database-password
FRONTEND_PORT=8080

# Default production image is the lean API/control-plane image. For a single-node
# AI pilot, set INSTALL_AI=true and STREAM_MANAGER_ENABLED=true together.
INSTALL_AI=false

STREAM_MANAGER_ENABLED=false
AV_FUSION_ENABLED=true
DATABASE_ECHO=false

VIDEO_LOG_ENABLED=false
VIDEO_LOG_LEVEL=WARNING
AUDIO_SESSION_RECORDING=false
AUDIO_EPISODE_RECORDING=true

CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30
DETECTION_INTERVAL=1.0
DETECTION_CONFIDENCE=0.15
DETECTION_IMGSZ=640
TOOLS_CONFIDENCE=0.45
FACE_MESH_WORKERS=2
TORCH_NUM_THREADS=4
