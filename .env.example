# Environment Configuration — Thaqib v1.0
# Copy this file to .env and update values as needed.
# Any variable left commented out will use the system default shown below.

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Thaqib
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# CAMERA SETTINGS
# =============================================================================
# Camera source: webcam index (0, 1, 2, ...), RTSP URL, or video file path
# Examples:
#   CAMERA_SOURCE=0
#   CAMERA_SOURCE=1
#   CAMERA_SOURCE=rtsp://192.168.1.100:554/stream
#   CAMERA_SOURCE=path/to/exam_video.mp4
CAMERA_SOURCE=0

# Capture resolution (pixels). Camera will attempt to use this resolution.
# Actual resolution depends on what the hardware supports.
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# =============================================================================
# DETECTION SETTINGS
# =============================================================================
# Seconds between full YOLO detection runs.
# Higher values = faster FPS, less frequent detection updates.
# Default: 1.0 (detects every second, tracks in between)
DETECTION_INTERVAL=1.0

# Person detection model (YOLOv11 medium — best speed/accuracy balance)
YOLO_MODEL=models/yolo11m.pt

# Minimum confidence for person detection (0.0–1.0).
# Lower = detect more people but more false positives.
DETECTION_CONFIDENCE=0.15

# YOLO inference resolution. 640 = fast, 1280 = more accurate at distance.
DETECTION_IMGSZ=640

# =============================================================================
# TOOLS DETECTION (Papers & Phones)
# =============================================================================
# Custom YOLO model for detecting exam papers and phones
TOOLS_MODEL=models/best.pt

# Class labels from the model to treat as "paper on desk"
TOOLS_TARGET_LABELS=["document"]

# Confidence threshold for paper/phone detection (0.0–1.0).
# Lower = more sensitive (catches more papers but more false positives).
TOOLS_CONFIDENCE=0.45

# =============================================================================
# TRACKING SETTINGS
# =============================================================================
# Maximum pixel distance to match a detection to an existing track
TRACKING_MAX_DISTANCE=100

# Frames before dropping a lost track (30 frames ≈ 1 second at 30fps)
TRACKING_MAX_AGE=30

# Number of nearest neighbors each student is compared against
NEIGHBOR_K=6

# =============================================================================
# CHEATING EVALUATION
# =============================================================================
# Maximum angle (degrees) between gaze direction and paper direction
# to consider the student "looking at" that paper.
# Larger = more tolerant (fewer missed detections), smaller = stricter.
RISK_ANGLE_TOLERANCE=25.0

# How many seconds a student must look at a neighbor's paper before
# the system flags it as cheating. Default: 2.0 seconds.
SUSPICIOUS_DURATION_THRESHOLD=2.0

# Fraction of consecutive frames that must show suspicious gaze (0.0–1.0)
SUSPICIOUS_MATCH_RATIO=0.7

# =============================================================================
# RE-IDENTIFICATION
# =============================================================================
# Cosine similarity threshold for matching a new tracker ID to a known student.
# Higher = stricter match required (fewer false re-IDs, more missed re-IDs).
# Range: 0.0–1.0. Recommended: 0.75–0.85.
REID_MATCH_THRESHOLD=0.80

# Set to true to print per-frame cosine similarity scores to the log.
# Useful for tuning REID_MATCH_THRESHOLD. Leave false in production.
REID_SIMILARITY_DEBUG=false

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Number of parallel worker processes for MediaPipe face mesh extraction.
# Recommended: 2–4. More workers = higher throughput but more RAM usage.
FACE_MESH_WORKERS=4

# PyTorch CPU thread count for inference. Leave blank to use OS default.
# TORCH_NUM_THREADS=4

# =============================================================================
# VIDEO OUTPUT
# =============================================================================
# Quality for saved video files (0–100). Lower = smaller files.
#   50 → LOW  (smallest files, reduced detail)
#   75 → MED  (default — good balance of size and quality)
#   90 → HIGH (best quality, larger files)
VIDEO_QUALITY=75

# Maximum height (pixels) to downscale alert video clips.
# Prevents multi-GB files when running on 4K cameras.
#   720  → ~720p  (recommended for most use cases)
#   1080 → ~1080p (higher quality, larger files)
#   0    → no downscaling (native resolution)
ALERT_MAX_HEIGHT=720

# =============================================================================
# ARCHIVE RECORDING
# =============================================================================
# Controls what gets saved to the archive/ folder during an exam session.
#   raw       → original camera feed, no overlays (smallest files, clean footage)
#   annotated → with bounding boxes, gaze arrows, and HUD overlays
ARCHIVE_MODE=raw
